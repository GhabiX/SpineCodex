{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "SpineTreeNode": {
      "properties": {
        "nodeId": {
          "type": "string"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/SpineTreeNodeStatus"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "nodeId",
        "status"
      ],
      "type": "object"
    },
    "SpineTreeNodeStatus": {
      "enum": [
        "live",
        "suspended",
        "closed"
      ],
      "type": "string"
    }
  },
  "properties": {
    "activeNodeId": {
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/definitions/SpineTreeNode"
      },
      "type": "array"
    },
    "snapshotSeq": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "activeNodeId",
    "nodes",
    "snapshotSeq",
    "threadId",
    "turnId"
  ],
  "title": "SpineTreeUpdatedNotification",
  "type": "object"
}