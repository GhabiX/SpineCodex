{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "SpineNodeContextBaselineSource": {
      "enum": [
        "provider_at_open",
        "root_compact_handoff",
        "estimated_from_live_suffix",
        "checkpoint_replay"
      ],
      "type": "string"
    },
    "SpineNodeContextProblem": {
      "enum": [
        "missing_current_usage",
        "missing_open_context_baseline",
        "coordinate_mismatch",
        "corrupt_pressure_metadata"
      ],
      "type": "string"
    },
    "SpinePlannedNode": {
      "properties": {
        "nodeId": {
          "type": "string"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "nodeId",
        "summary"
      ],
      "type": "object"
    },
    "SpineTreeNode": {
      "properties": {
        "accounting": {
          "anyOf": [
            {
              "$ref": "#/definitions/SpineTreeNodeAccounting"
            },
            {
              "type": "null"
            }
          ]
        },
        "nodeId": {
          "type": "string"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/SpineTreeNodeStatus"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "nodeId",
        "status"
      ],
      "type": "object"
    },
    "SpineTreeNodeAccounting": {
      "properties": {
        "closedMemoryContextTokens": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "closedSourceSuffixTokens": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "currentNodeContextBaselineSource": {
          "anyOf": [
            {
              "$ref": "#/definitions/SpineNodeContextBaselineSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "currentNodeContextProblem": {
          "anyOf": [
            {
              "$ref": "#/definitions/SpineNodeContextProblem"
            },
            {
              "type": "null"
            }
          ]
        },
        "currentNodeContextTokens": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "memoryOutputTokens": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "SpineTreeNodeStatus": {
      "enum": [
        "live",
        "opened",
        "closed",
        "compacted"
      ],
      "type": "string"
    }
  },
  "properties": {
    "activeNodeId": {
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/definitions/SpineTreeNode"
      },
      "type": "array"
    },
    "plannedNodes": {
      "default": [],
      "items": {
        "$ref": "#/definitions/SpinePlannedNode"
      },
      "type": "array"
    },
    "snapshotSeq": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "activeNodeId",
    "nodes",
    "snapshotSeq",
    "threadId",
    "turnId"
  ],
  "title": "SpineTreeUpdatedNotification",
  "type": "object"
}